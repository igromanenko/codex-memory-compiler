{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/session-start.py",
            "timeout": 15,
            "statusMessage": "Loading knowledge base context"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/stop.py",
            "timeout": 15,
            "statusMessage": "Extracting durable memory"
          }
        ]
      }
    ]
  }
}
